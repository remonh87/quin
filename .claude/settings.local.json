{
  "permissions": {
    "allow": [
      "mcp__apple-calendar__get_events",
      "mcp__apple-calendar__get_calendars",
      "mcp__apple-calendar__get_today_events",
      "Read(//Users/remon/.claude/**)",
      "Read(//Users/remon/Library/**)",
      "mcp__plugin_todoist_todoist__*",
      "mcp__apple-events__calendar_events",
      "mcp__apple-events__calendar_calendars"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "todoist@doist": true
  },
  "mcpServers": {
    "apple-reminders": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-apple-events"
      ]
    }
  }
}
